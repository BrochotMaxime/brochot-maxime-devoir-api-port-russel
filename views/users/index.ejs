<!DOCTYPE html>
<html lang="fr">
<%- include('../partials/head') %>
<body>
        <%- include('../partials/nav') %>
        <main>
                <h1><%= title %></h1>
                <p><a href="/users-page/new">Créer un nouvel utilisateur</a></p>
                <% if (users && users.length > 0) { %>
                        <table>
                                <thead>
                                        <tr>
                                                <th>Nom d'utilisateur</th>
                                                <th>Email</th>
                                                <th>Créé le</th>
                                                <th>Action</th>
                                        </tr>
                                </thead>
                                <tbody>
                                        <% users.forEach(userItem => { %>
                                                <tr>
                                                        <td><%= userItem.username %></td>
                                                        <td><%= userItem.email %></td>
                                                        <td><%= new Date(userItem.createdAt).toLocaleDateString('fr-FR') %></td>
                                                        <td>
                                                                <a href="/users-page/<%= userItem.email %>">Détail</a>
                                                                |
                                                                <a href="/users-page/<%= userItem.email %>/edit">Modifier</a>
                                                                |
                                                                <form action="/users-page/<%= userItem.email %>/delete" method="POST" ">
                                                                        <button type="submit" onclick="return confirm('Supprimer cet utilisateur ?')">Supprimer</button>
                                                                </form>
                                                        </td>
                                                </tr>
                                        <% }) %>
                                </tbody>
                        </table>
                <% } else { %>
                        <p>Aucun utilisateur disponible.</p>
                <% } %>
        </main>
</body>
</html>