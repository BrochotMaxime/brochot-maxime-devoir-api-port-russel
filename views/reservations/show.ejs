<!DOCTYPE html>
<html lang="fr">
<%- include('../partials/head') %>
<body>
        <%- include('../partials/nav') %>
        <main>
                <h1><%= title %></h1>
                <section>
                        <p><strong>Catway :</strong> <%= reservation.catwayNumber %></p>
                        <p><strong>Client :</strong> <%= reservation.clientName %></p>
                        <p><strong>Bateau :</strong> <%= reservation.boatName %></p>
                        <p><strong>Date de début :</strong> <%= new Date(reservation.startDate).toLocaleDateString('fr-FR') %></p>
                        <p><strong>Date de fin :</strong> <%= new Date(reservation.endDate).toLocaleDateString('fr-FR') %></p>
                        <p><strong>Créée le :</strong> <%= new Date(reservation.createdAt).toLocaleDateString('fr-FR') %></p>
                        <p><strong>Mise à jour le :</strong> <%= new Date(reservation.updatedAt).toLocaleDateString('fr-FR') %></p>
                </section>
                <p><a href="/reservations-page">Retour à la liste des réservations</a></p>
        </main>
</body>
</html>