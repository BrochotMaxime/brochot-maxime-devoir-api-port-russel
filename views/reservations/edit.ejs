<!DOCTYPE html>
<html lang="fr">
<%- include('../partials/head') %>
<body>
        <%- include('../partials/nav') %>
        <main>
                <h1><%= title %></h1>
                <form action="/reservations-page/<%= reservation._id %>/update" method="POST">
                        <div>
                                <label for="catwayNumber">Catway :</label>
                                <select id="catwayNumber" name="catwayNumber" required>
                                        <% catways.forEach(catway => { %>
                                                <option value="<%= catway.catwayNumber %>"
                                                        <%= catway.catwayNumber === reservation.catwayNumber ? 'selected' : '' %>>
                                                        <%= catway.catwayNumber %> - <%= catway.catwayType %>
                                                </option>
                                        <% }) %>
                                </select>
                        </div>
                        <div>
                                <label for="clientName">Client :</label>
                                <input type="text" id="clientName" name="clientName" value="<%= reservation.clientName %>" required>
                        </div>
                        <div>
                                <label for="boatName">Bateau :</label>
                                <input type="text" id="boatName" name="boatName" value="<%= reservation.boatName %>" required>
                        </div>
                        <div>
                                <label for="startDate">Date de début :</label>
                                <input type="date" id="startDate" name="startDate" value="<%= new Date(reservation.startDate).toISOString().split('T')[0] %>" required>
                        </div>
                        <div>
                                <label for="endDate">Date de fin :</label>
                                <input type="date" id="endDate" name="endDate" value="<%= new Date(reservation.endDate).toISOString().split('T')[0] %>" required>
                        </div>
                        <button type="submit">Mettre à jour la réservation</button>
                </form>
                <p><a href="/reservations-page/<%= reservation._id %>">Retour au détail</a></p>
        </main>
</body>
</html>