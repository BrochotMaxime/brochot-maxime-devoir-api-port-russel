<!DOCTYPE html>
<html lang="fr">
<%- include('../partials/head') %>
<body>
        <%- include('../partials/nav') %>
        <main>
                <h1><%= title %></h1>
                <section>
                        <p><strong>Numéro :</strong> <%= catway.catwayNumber %></p>
                        <p><strong>Type :</strong> <%= catway.catwayType %></p>
                        <p><strong>État :</strong> <%= catway.catwayState %></p>
                        <p><strong>Créé le :</strong> <%= new Date(catway.createdAt).toLocaleDateString('fr-FR') %></p>
                        <p><strong>Mis à jour le :</strong> <%= new Date(catway.updatedAt).toLocaleDateString('fr-FR') %></p>
                </section>
                <p><a href="/catways-page">Retour à la liste des catways</a></p>
        </main>
</body>
</html>